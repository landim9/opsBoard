# ============================================================
# OpsBoard Web — Variáveis de Ambiente
# Copie para .env.local e preencha os valores antes de iniciar
# ============================================================

# NextAuth (obrigatório) — use: openssl rand -hex 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# URL da API Fastify
NEXT_PUBLIC_API_URL=http://localhost:3001

# Stripe
NEXT_PUBLIC_STRIPE_PRO_URL=/pricing

# Stub de desenvolvimento (apenas desenvolvimento — NÃO usar em produção)
DEV_STUB_EMAIL=dev@opsboard.local
DEV_STUB_PASSWORD=
